resource "null_resource" "example" {
  provisioner "local-exec" {
    interpreter = ["/bin/bash", "-c"]
    command = <<EOT
      set -e

      trap 'echo "ERROR: Line $LINENO - Exit code $?" >&2' ERR

      echo "Starting script..."

      # Example failure
      ls /not/exist

      echo "Completed"
    EOT
  }
}
